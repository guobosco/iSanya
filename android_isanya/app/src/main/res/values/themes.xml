<!-- 文件说明：默认主题与窗口样式（浅色等）。 -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Lulu" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/brand_cream</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:colorPrimary">@color/brand_pink</item>
        <item name="android:colorPrimaryDark">@color/brand_pink_dark</item>
        <item name="android:colorAccent">@color/brand_pink_dark</item>
        <item name="android:colorBackground">@color/brand_cream</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.Lulu">
        <item name="android:windowBackground">#EB2C5F</item>
        <item name="android:statusBarColor">#EB2C5F</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
